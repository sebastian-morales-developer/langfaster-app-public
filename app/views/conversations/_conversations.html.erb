<div class="album py-5 ebriwer-bg-body-1">
    
    <div class="container">
        <h2><%= t("find_more_conversations_created") %></h2> <br>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3  g-3">
            <% if @conversations.present? %>
                <% @conversations.reverse.each do |conversation| %>
                    <%= render conversation %>
                <% end %>
            <% else %>
                <p><%= t("no_conversations_available") %></p>
            <% end %>
        </div>
    </div>
        
</div>